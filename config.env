# FastVM Configuration File
# Customize these settings before running fastvm-install.sh

# =============================================================================
# NETWORK CONFIGURATION
# =============================================================================

# Main web interface port (default: 3000)
FASTVM_PORT=3000

# Container name (default: FastVM)
FASTVM_NAME=FastVM

# =============================================================================
# USER CONFIGURATION
# =============================================================================

# User ID and Group ID for file permissions
# Change if you need different ownership (default: 1000)
FASTVM_PUID=1000
FASTVM_PGID=1000

# Timezone (default: Etc/UTC)
# Examples: America/New_York, Europe/London, Asia/Tokyo
FASTVM_TZ=Etc/UTC

# =============================================================================
# RESOURCE LIMITS
# =============================================================================

# Shared memory size (default: 2gb)
# Increase for better performance with heavy applications
FASTVM_SHM_SIZE=4gb

# CPU limit (number of cores, e.g., 2, 4, or 0 for unlimited)
FASTVM_CPU_LIMIT=2

# Memory limit (e.g., 4g, 8g, or 0 for unlimited)
FASTVM_MEMORY_LIMIT=8

# =============================================================================
# FEATURES
# =============================================================================

# Enable KVM acceleration (true/false)
# Set to true for better performance if /dev/kvm is available
FASTVM_ENABLE_KVM=true

# Subfolder path (default: /)
FASTVM_SUBFOLDER=/

# Window title in browser tab
FASTVM_TITLE=FastVM

# =============================================================================
# DESKTOP ENVIRONMENT
# =============================================================================

# Choose your desktop environment:
# Options: KDE, XFCE4, I3, GNOME, Cinnamon, LXQT
# KDE = Full-featured, heavy resource usage
# XFCE4 = Balanced, lightweight
# I3 = Tiling window manager, very lightweight
# GNOME = Modern, very heavy
# Cinnamon = Traditional desktop, medium weight
# LXQT = Lightweight Qt-based desktop
FASTVM_DE=XFCE4

# =============================================================================
# APPLICATION SELECTION
# =============================================================================

# Default Apps (set to true to install)
FASTVM_APP_WINE=true
FASTVM_APP_CHROME=true
FASTVM_APP_XARCHIVER=false
FASTVM_APP_DISCORD=false
FASTVM_APP_STEAM=false
FASTVM_APP_MINECRAFT=false

# Programming Tools
FASTVM_PROG_JAVA8=false
FASTVM_PROG_JAVA17=false
FASTVM_PROG_VSCODIUM=false

# Additional Apps
FASTVM_APP_VLC=false
FASTVM_APP_LIBREOFFICE=false
FASTVM_APP_SYNAPTIC=false
FASTVM_APP_AQEMU=false
FASTVM_APP_TLAUNCHER=false

# =============================================================================
# ADVANCED OPTIONS
# =============================================================================

# Restart policy: no, on-failure, always, unless-stopped
FASTVM_RESTART_POLICY=on-failure

# Enable health checks (true/false)
FASTVM_HEALTHCHECK=true

# Health check interval (default: 30s)
FASTVM_HEALTH_INTERVAL=30s

# Health check timeout (default: 10s)
FASTVM_HEALTH_TIMEOUT=10s

# Log level: debug, info, warn, error
FASTVM_LOG_LEVEL=info
