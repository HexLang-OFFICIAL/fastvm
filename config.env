# FastVM Configuration File
# Edit before running ./fastvm-install.sh
# All FASTVM_* variables are exported to the container automatically.

# =============================================================================
# NETWORK
# =============================================================================

# Main KasmVNC web interface (default: 3000)
FASTVM_PORT=3000

# Management dashboard port (default: 3001)
FASTVM_DASHBOARD_PORT=3001

# Container name
FASTVM_NAME=FastVM

# =============================================================================
# USER
# =============================================================================

FASTVM_PUID=1000
FASTVM_PGID=1000

# Timezone — e.g. America/New_York, Europe/London, Asia/Tokyo
FASTVM_TZ=Etc/UTC

# =============================================================================
# RESOURCES
# =============================================================================

# Shared memory (increase for heavy apps / gaming)
FASTVM_SHM_SIZE=4gb

# CPU cores (0 = unlimited)
FASTVM_CPU_LIMIT=2

# RAM limit (0 = unlimited; e.g. 4g, 8g)
FASTVM_MEMORY_LIMIT=8g

# =============================================================================
# DESKTOP ENVIRONMENT
# =============================================================================

# Options: KDE, XFCE4, I3, GNOME, Cinnamon, LXQT, Budgie
# Budgie = modern, lightweight, recommended for 4 GB+ RAM
FASTVM_DE=XFCE4

# =============================================================================
# PRESET (optional — overlays app + resource defaults)
# =============================================================================

# Options: none, minimal, gaming, development, office, content-creation
# When a preset is set, it overrides individual app selections below.
FASTVM_PRESET=none

# =============================================================================
# APPLICATION SELECTION
# =============================================================================

# Default Apps
FASTVM_APP_WINE=true
FASTVM_APP_CHROME=true
FASTVM_APP_XARCHIVER=false
FASTVM_APP_DISCORD=false
FASTVM_APP_STEAM=false
FASTVM_APP_MINECRAFT=false

# Programming Tools
FASTVM_PROG_JAVA8=false
FASTVM_PROG_JAVA17=false
FASTVM_PROG_VSCODIUM=false

# Additional Apps
FASTVM_APP_VLC=false
FASTVM_APP_LIBREOFFICE=false
FASTVM_APP_SYNAPTIC=false
FASTVM_APP_AQEMU=false
FASTVM_APP_TLAUNCHER=false

# =============================================================================
# AUDIO
# =============================================================================

# Enable PulseAudio inside the container (true/false)
FASTVM_AUDIO_ENABLED=true

# =============================================================================
# CLIPBOARD SYNC
# =============================================================================

# Bidirectional clipboard between browser and desktop (true/false)
FASTVM_CLIPBOARD_ENABLED=true

# =============================================================================
# SCREEN RECORDING
# =============================================================================

FASTVM_RECORDING_ENABLED=true

# Output format: mp4, webm, mkv
FASTVM_RECORDING_FORMAT=mp4

# Video bitrate
FASTVM_RECORDING_BITRATE=5M

# Frames per second
FASTVM_RECORDING_FRAMERATE=30

# Codec: h264, hevc, vp9
FASTVM_RECORDING_CODEC=h264

# =============================================================================
# SNAPSHOT / BACKUP
# =============================================================================

# Master switch
FASTVM_BACKUP_ENABLED=true

# Automatic schedule: disabled, daily, weekly, hourly
FASTVM_BACKUP_AUTO_SCHEDULE=daily

# Days to keep old snapshots (0 = keep forever)
FASTVM_BACKUP_RETENTION_DAYS=30

# Compression: gzip, zstd, xz
FASTVM_BACKUP_COMPRESSION=gzip

# =============================================================================
# AUTO-SCALING
# =============================================================================

# Dynamically adjust CPU/memory limits (disabled by default — opt-in)
FASTVM_AUTOSCALE_ENABLED=false
FASTVM_AUTOSCALE_MIN_CPU=1
FASTVM_AUTOSCALE_MAX_CPU=4
FASTVM_AUTOSCALE_MIN_MEMORY=2g
FASTVM_AUTOSCALE_MAX_MEMORY=8g
FASTVM_AUTOSCALE_CPU_THRESHOLD=80
FASTVM_AUTOSCALE_MEMORY_THRESHOLD=80
FASTVM_AUTOSCALE_INTERVAL=30

# =============================================================================
# FEATURES
# =============================================================================

# URL subfolder path (default: /)
FASTVM_SUBFOLDER=/

# Browser tab title
FASTVM_TITLE=FastVM

# Enable KVM acceleration (requires /dev/kvm on host)
FASTVM_ENABLE_KVM=false

# =============================================================================
# ADVANCED
# =============================================================================

# Restart policy: no, on-failure, always, unless-stopped
FASTVM_RESTART_POLICY=on-failure

# Disable health checks
FASTVM_HEALTHCHECK_DISABLE=false

FASTVM_HEALTH_INTERVAL=30s
FASTVM_HEALTH_TIMEOUT=10s

# Log level: debug, info, warn, error
FASTVM_LOG_LEVEL=info
