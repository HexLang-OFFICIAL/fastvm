# FastVM "content-creation" preset
# GIMP + Audacity + ffmpeg + screen recording with high bitrate.

FASTVM_DE=XFCE4
FASTVM_SHM_SIZE=4gb
FASTVM_CPU_LIMIT=4
FASTVM_MEMORY_LIMIT=8g

FASTVM_APP_VLC=true
FASTVM_APP_CHROME=true
FASTVM_APP_LIBREOFFICE=true

FASTVM_AUDIO_ENABLED=true
FASTVM_CLIPBOARD_ENABLED=true
FASTVM_RECORDING_ENABLED=true
FASTVM_RECORDING_BITRATE=10M
FASTVM_RECORDING_FRAMERATE=60
FASTVM_RECORDING_CODEC=h264

FASTVM_PRESET_INSTALL_GIMP=true
FASTVM_PRESET_INSTALL_AUDACITY=true
FASTVM_PRESET_INSTALL_OBS=true
FASTVM_PRESET_INSTALL_FFMPEG=true
