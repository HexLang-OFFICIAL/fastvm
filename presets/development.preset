# FastVM "development" preset
# Editor, JDKs, container tooling, generous CPU.

FASTVM_DE=XFCE4
FASTVM_SHM_SIZE=4gb
FASTVM_CPU_LIMIT=4
FASTVM_MEMORY_LIMIT=8g

FASTVM_APP_CHROME=true
FASTVM_APP_WINE=false
FASTVM_APP_STEAM=false
FASTVM_APP_XARCHIVER=true

FASTVM_PROG_JAVA8=true
FASTVM_PROG_JAVA17=true
FASTVM_PROG_VSCODIUM=true

FASTVM_AUDIO_ENABLED=true
FASTVM_CLIPBOARD_ENABLED=true

FASTVM_PRESET_INSTALL_GIT=true
FASTVM_PRESET_INSTALL_NODE=true
FASTVM_PRESET_INSTALL_PYTHON=true
FASTVM_PRESET_INSTALL_DOCKER_CLI=true
