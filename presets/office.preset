# FastVM "office" preset
# LibreOffice, browsers, light productivity stack.

FASTVM_DE=XFCE4
FASTVM_SHM_SIZE=2gb
FASTVM_CPU_LIMIT=2
FASTVM_MEMORY_LIMIT=4g

FASTVM_APP_LIBREOFFICE=true
FASTVM_APP_CHROME=true
FASTVM_APP_VLC=true
FASTVM_APP_XARCHIVER=true

FASTVM_APP_WINE=false
FASTVM_APP_STEAM=false
FASTVM_APP_MINECRAFT=false

FASTVM_AUDIO_ENABLED=true
FASTVM_CLIPBOARD_ENABLED=true
