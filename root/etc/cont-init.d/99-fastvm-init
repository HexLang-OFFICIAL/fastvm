#!/usr/bin/with-contenv bash
# Container init: install FastVM scripts into /fastvm-scripts and configure
# default cron tasks. Intentionally permissive — never abort s6 boot, since
# that would prevent KasmVNC and the desktop from starting.

# NOTE: do NOT use `set -e` here. cont-init.d scripts that abort prevent the
# whole stack (including nginx + KasmVNC) from coming up.

# 1. Stage scripts at a stable path
mkdir -p /fastvm-scripts
if [[ -d /opt/fastvm-scripts ]]; then
    cp -f /opt/fastvm-scripts/*.sh /fastvm-scripts/ 2>/dev/null || true
    chmod +x /fastvm-scripts/*.sh 2>/dev/null || true
fi

# 2. Runtime dirs (cheap; no recursive chown of /config — can be huge)
mkdir -p /config/backups /config/recordings /config/.fastvm /var/log/fastvm 2>/dev/null || true
chown abc:abc /config/backups /config/recordings /config/.fastvm /var/log/fastvm 2>/dev/null || true

# 3. Default scheduled tasks (best-effort — never fatal)
{
    if [[ "${FASTVM_BACKUP_ENABLED:-true}" == "true" ]] && [[ ! -s /config/.fastvm/tasks.json ]]; then
        FASTVM_DATA_ROOT=/config /fastvm-scripts/task-manager.sh init >/dev/null 2>&1 || true
    fi

    schedule_map() {
        case "$1" in
            daily)  echo "0 2 * * *" ;;
            weekly) echo "0 2 * * 0" ;;
            hourly) echo "0 * * * *" ;;
            *)      echo "" ;;
        esac
    }
    sched=$(schedule_map "${FASTVM_BACKUP_AUTO_SCHEDULE:-daily}")
    if [[ -n "$sched" ]] && [[ "${FASTVM_BACKUP_ENABLED:-true}" == "true" ]]; then
        FASTVM_DATA_ROOT=/config /fastvm-scripts/task-manager.sh add \
            daily-backup "$sched" "/fastvm-scripts/backup-scheduler.sh" >/dev/null 2>&1 || true
    fi
} || true

exit 0
